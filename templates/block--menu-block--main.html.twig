{#
/**
 * @file
 * Theme override for a Main (Red Bar) menu block.
 *
 * This file is used for the "Main navigation" block provided by the
 * menu_block module.
 *
 * See also: block--system-menu-block--main.html.twig
 */
#}
{% extends "block.html.twig" %}
{% block content %}
  {% include wdn.directory ~ "/includes/global/nav-menu-1.html" %}
  {% include wdn.directory ~ "/includes/global/nav-local-1.html" %}
    <!-- InstanceBeginEditable name="navlinks" -->
    {{ content }}
    <!-- InstanceEndEditable -->
  {% include wdn.directory ~ "/includes/global/nav-local-2.html" %}
  {% include wdn.directory ~ "/includes/global/nav-menu-2.html" %}
  {% include wdn.directory ~ "/includes/global/nav-dialog-1.html" %}
  {% include wdn.directory ~ "/includes/global/nav-local-copy-dialog.html" %}
  {% include wdn.directory ~ "/includes/global/cta-1.html" %}
  {% include wdn.directory ~ "/includes/global/visit-1.html" %}
  <!-- InstanceBeginEditable name="navvisit" -->
  {% if visit_apply_give_nav_data["visit_nav"]["visit_nav_url"] is not empty %}
    <li><a href="{{ visit_apply_give_nav_data["visit_nav"]["visit_nav_url"] }}">{{ visit_apply_give_nav_data["visit_nav"]["visit_nav_link_text"] }}</a></li>
  {% endif %}
  <!-- InstanceEndEditable -->
  {% include wdn.directory ~ "/includes/global/visit-2.html" %}
  {% include wdn.directory ~ "/includes/global/apply-1.html" %}
  <!-- InstanceBeginEditable name="navapply" -->
  {% if visit_apply_give_nav_data["apply_nav"]["apply_nav_url"] is not empty %}
    <li><a href="{{ visit_apply_give_nav_data["apply_nav"]["apply_nav_url"] }}">{{ visit_apply_give_nav_data["apply_nav"]["apply_nav_link_text"] }}</a></li>
  {% endif %}
  <!-- InstanceEndEditable -->
  {% include wdn.directory ~ "/includes/global/apply-2.html" %}
  {% include wdn.directory ~ "/includes/global/give-1.html" %}
  <!-- InstanceBeginEditable name="navgive" -->
  {% if visit_apply_give_nav_data["give_nav"]["give_nav_url"] is not empty %}
    <li><a href="{{ visit_apply_give_nav_data["give_nav"]["give_nav_url"] }}">{{ visit_apply_give_nav_data["give_nav"]["give_nav_link_text"] }}</a></li>
  {% endif %}
  <!-- InstanceEndEditable -->
  {% include wdn.directory ~ "/includes/global/give-2.html" %}
  {% include wdn.directory ~ "/includes/global/cta-2.html" %}
  {% include wdn.directory ~ "/includes/global/nav-dialog-2.html" %}
  {% include wdn.directory ~ "/includes/global/nav-container-2.html" %}
{% endblock %}
